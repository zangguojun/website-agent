# 复制为本目录下的 `.env`（或按需拆到各 app 的运行目录），勿提交真实密钥。

# -----------------------------------------------------------------------------
# apps/api（Next.js；在 apps/api 下启动时也会在 apps/api/.env.local 读取同名变量）
# -----------------------------------------------------------------------------

# 可选。未设置时使用内存存储（仅开发 / 演示 / 测试）。
DATABASE_URL="postgres://user:password@localhost:5432/website_agent"

# 需要登录态 Authorization: Bearer 时配置；不设则仅用匿名 x-device-id。
CLERK_SECRET_KEY="sk_test_example"

# LLM（OpenAI 兼容接口）。不设 OPENAI_API_KEY 时，计划 / 出题等可走离线确定性生成。
OPENAI_API_KEY=""
# 可选。省略则请求官方 api.openai.com。百炼（DashScope）OpenAI 兼容示例：
# https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_BASE_URL=""
# 可选。默认 gpt-4o-mini；百炼请改为千问型号，例如 qwen-plus。
OPENAI_MODEL=""

# -----------------------------------------------------------------------------
# apps/mobile（Expo）
# -----------------------------------------------------------------------------

# 开发构建可不填（会按 Metro host 推断）；真机请用电脑的局域网 IP。生产必填。
EXPO_PUBLIC_API_BASE_URL="http://localhost:3000"

# 可选：离线 mock UI / E2E，见 README。
# EXPO_PUBLIC_MOCK_AGENT="true"
